/**
 * 【追加】現在登録されているAPIキーを（一部伏せ字で）確認する関数
 */
function showCurrentSettings() {
  const ui = SpreadsheetApp.getUi();
  const props = PropertiesService.getScriptProperties();

  const gemini = props.getProperty('GEMINI_API_KEY') || '未登録';
  const weather = props.getProperty('OPENWEATHER_API_KEY') || '未登録';
  const slack = props.getProperty('SLACK_WEBHOOK_URL') || '未登録';

  // セキュリティのため、長いキーは一部を伏せ字にして表示する関数
  const mask = (str) => {
    if (str === '未登録') return str;
    if (str.length <= 10) return '********'; 
    return str.substring(0, 5) + '...' + str.substring(str.length - 4);
  };

  const message = 
    `現在の登録状況は以下の通りです。\n\n` +
    `■ Gemini APIキー:\n ${mask(gemini)}\n\n` +
    `■ OpenWeather APIキー:\n ${mask(weather)}\n\n` +
    `■ Slack Webhook URL:\n ${mask(slack)}\n\n` +
    `※変更したい場合は「🔑 APIキー・Webhookの登録」から新しい値で上書きしてください。`;

  ui.alert('登録済み設定の確認', message, ui.ButtonSet.OK);
}

/**
 * 秘密情報を入力するダイアログを表示し、Script Propertiesに保存する
 */
function showSettingsDialog() {
  const ui = SpreadsheetApp.getUi();
  const props = PropertiesService.getScriptProperties();

  const settings = [
    { key: 'GEMINI_API_KEY', label: 'Gemini APIキー' },
    { key: 'OPENWEATHER_API_KEY', label: 'OpenWeather APIキー' },
    { key: 'SLACK_WEBHOOK_URL', label: 'Slack Webhook URL' }
  ];

  for (let i = 0; i < settings.length; i++) {
    let s = settings[i];
    const current = props.getProperty(s.key) ? "【登録済】" : "【未登録】";
    const res = ui.prompt(s.label + ' の設定', current + ' 新しい値を入力してください\n（変更しない場合・後で設定する場合は空欄のままOK）', ui.ButtonSet.OK_CANCEL);
    
    if (res.getSelectedButton() == ui.Button.CANCEL) {
      ui.alert('設定を中断しました。');
      return;
    }
    
    const val = res.getResponseText().trim();
    if (val) props.setProperty(s.key, val);
  }
  
  ui.alert('設定完了', '入力された情報を安全な領域に保存しました。', ui.ButtonSet.OK);
}

